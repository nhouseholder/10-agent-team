      "dark": "macOverlay2",
      "light": "macOverlay2"
    },
    "syntaxKeyword": {
      "dark": "macAccent",
      "light": "macAccent"
    },
    "syntaxFunction": {
      "dark": "macBlue",
      "light": "macBlue"
    },
    "syntaxVariable": {
      "dark": "macRed",
      "light": "macRed"
    },
    "syntaxString": {
      "dark": "macGreen",
      "light": "macGreen"
    },
    "syntaxNumber": {
      "dark": "macPeach",
      "light": "macPeach"
    },
    "syntaxType": {
      "dark": "macYellow",
      "light": "macYellow"
    },
    "syntaxOperator": {
      "dark": "macSky",
      "light": "macSky"
