{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "macAccent": "#99d1db",
    "macRosewater": "#eebebe",
    "macFlamingo": "#eebebe",
    "macPink": "#f4b8e4",
    "macMauve": "#ca9ee6",
    "macRed": "#e78284",
    "macMaroon": "#ea999c",
    "macPeach": "#ef9f76",
    "macYellow": "#e5c890",
    "macGreen": "#a6d189",
    "macTeal": "#81c8be",
    "macSky": "#99d1db",
