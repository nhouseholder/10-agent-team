  "theme": {
    "primary": {
      "dark": "macAccent",
      "light": "macAccent"
    },
    "secondary": {
      "dark": "macAccent",
      "light": "macAccent"
    },
    "accent": {
      "dark": "macPink",
      "light": "macPink"
    },
    "error": {
      "dark": "macRed",
      "light": "macRed"
    },
    "warning": {
      "dark": "macYellow",
      "light": "macYellow"
