    "macLavender": "#babbf1",
    "macText": "#c6d0f5",
    "macSubtext1": "#b5bfe2",
    "macSubtext0": "#a5adce",
    "macOverlay2": "#949cbb",
    "macOverlay1": "#838ba7",
    "macOverlay0": "#737994",
    "macSurface2": "#626880",
    "macSurface1": "#51576d",
